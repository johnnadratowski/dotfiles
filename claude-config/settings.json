{
  "permissions": {
    "allow": [
      "Bash(npm run typecheck:*)",
      "Bash(npm run lint)",
      "Bash(npx eslint:*)",
      "Bash(forge test:*)",
      "Bash(npm run sync:*)",
      "Bash(make:*)",
      "Bash(cat:*)",
      "Bash(npx next build:*)",
      "Bash(npm run build:*)",
      "Bash(npm install:*)",
      "Bash(npm run tsc:*)",
      "Bash(find:*)",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "Bash(xargs ls:*)",
      "Bash(yarn tsc:*)",
      "Bash(npm uninstall:*)",
      "Bash(grep:*)",
      "Bash(git checkout:*)",
      "Bash(*john-send.sh:*)",
      "Bash(*john-broadcast.sh:*)",
      "Bash(*john-fanout.sh:*)",
      "Bash(*john-msg.sh:*)",
      "Bash(*agent-send.sh:*)",
      "Bash(*agent-broadcast.sh:*)",
      "Bash(*agent-fanout.sh:*)",
      "Bash(*agent-msg.sh:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'r=$(git -C \"${CLAUDE_PROJECT_DIR:-$PWD}\" rev-parse --show-toplevel 2>/dev/null) || exit 0; [ -x \"$r/.claude/hooks/register-agent.sh\" ] || exit 0; exec bash \"$r/.claude/hooks/register-agent.sh\" sessionstart'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "claude-notifications-go@claude-notifications-go": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark-daltonized",
  "editorMode": "normal",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "tui": "fullscreen"
}
